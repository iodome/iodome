{
  "name": "iodome-test-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "db:console": "psql iodome_test_next_development",
    "db:migrate": "prisma migrate dev; dotenv -e .env.test prisma migrate dev",
    "db:push": "prisma db push; dotenv -e .env.test prisma db push --accept-data-loss",
    "dev": "next dev --turbopack --port=3001",
    "lint": "next lint",
    "start": "next start",
    "test": "vitest run && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "@iodome/playwright": "workspace:*",
    "@iodome/vitest": "workspace:*",
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@prisma/client": "^6.3.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.1",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "15.3.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.3"
  },
  "type": "module",
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.2"
    }
  }
}
